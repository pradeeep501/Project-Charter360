# --- AI generation (server-side only; the key is never exposed to the browser) ---
# Get a key at https://console.anthropic.com  → API Keys
# If unset, the app falls back to a built-in mock generator so you can still demo.
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Storage (optional). If unset, charters save to your browser (localStorage). ---
# Create a project at https://supabase.com and run supabase/schema.sql in the SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
